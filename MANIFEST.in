# ABOUTME: Manifest file to include non-Python files in package distribution
# ABOUTME: Ensures data files are included when building the package

include README.md
include LICENSE
include src/jaff/registry.txt

recursive-include src/jaff/data *.dat
recursive-include src/jaff/templates *.hpp *.cpp *.txt
recursive-include src/jaff/db *.db

setup(
    package_data={"jaff": ["registry.txt"]},
)
